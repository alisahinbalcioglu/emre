# ───────────────────────────────────────────────────────────
# Python DWG Engine — Environment template
# Kopyala: cp .env.example .env, degerleri doldur.
# ───────────────────────────────────────────────────────────

# Port — Render PORT env'ini kendisi atar, locale 8011 default.
PORT=8011

# Internal auth token — NestJS'ten gelen istekleri dogrulamak icin.
# Locale: bos birakilirsa auth devre disi.
# Production: Render 'generateValue: true' otomatik ayni token'i NestJS'e de verir.
INTERNAL_API_TOKEN=""

# Anthropic Claude API — cap atama icin
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=""
