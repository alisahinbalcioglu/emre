# ───────────────────────────────────────────────────────────
# MetaPrice Backend — Environment template
# Kopyala: cp .env.example .env, sonra gercek degerleri doldur.
# .env dosyasi .gitignore'da — ASLA commit etme.
# ───────────────────────────────────────────────────────────

# Database — PostgreSQL
# Locale: docker-compose ile calisan Postgres
# Production: Render Postgres "Internal Connection String"
DATABASE_URL="postgresql://postgres:password@localhost:5432/metaprice"

# JWT auth
# Production: Render'da 'generateValue: true' ile otomatik uretilir
# Locale: en az 32 karakter rastgele secret (openssl rand -base64 32)
JWT_SECRET="change-me-to-a-strong-random-secret-min-32-chars"
JWT_EXPIRES_IN="7d"

# NestJS API port
# Locale: 3001 default. Render kendi PORT'unu atar (otomatik)
PORT=3001

# CORS izinli origin'ler — virgulle ayri.
# Locale: localhost portlari yeterli
# Production: Netlify frontend URL'i ekle (ornek: https://metaprice.netlify.app)
CORS_ORIGINS="http://localhost:3000,http://localhost:3002,http://localhost:3003"

# ───────────────────────────────────────────────────────────
# Python DWG Engine baglantisi (ayri servis)
# ───────────────────────────────────────────────────────────

# Acik URL (dev): http://localhost:8011
# Render production: DWG_ENGINE_HOST ile host verilir, https otomatik eklenir
DWG_ENGINE_URL="http://localhost:8011"
# DWG_ENGINE_HOST="metaprice-dwg-engine-abc.onrender.com"   # Render set eder

# Python engine'e giden isteklerin guvenlik token'i.
# Locale: bos birakilabilir (auth bypass). Production: Render otomatik uretir.
DWG_ENGINE_TOKEN=""

# ───────────────────────────────────────────────────────────
# AI saglayicilari
# ───────────────────────────────────────────────────────────

# Anthropic Claude API — cap atama + ekipman tanima icin
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=""
