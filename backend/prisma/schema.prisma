generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  user
}

enum UserStatus {
  active
  banned
}

enum Tier {
  core
  pro
  suite
}

enum PackageLevel {
  core
  pro
}

enum SubscriptionScope {
  mechanical
  electrical
  mep
}

model User {
  id             String              @id @default(uuid())
  email          String              @unique
  password       String
  role           Role                @default(user)
  status         UserStatus          @default(active)
  tier           Tier                @default(core)
  createdAt      DateTime            @default(now())
  library        UserLibrary[]
  brandLibraries UserBrandLibrary[]
  laborFirms     LaborFirm[]
  quotes         Quote[]
  subscriptions  UserSubscription[]
}

// ESLESME HAFIZASI (PRD Adim 8) — belirsiz satirda kullanicinin sectigi urunu
// hatirlar. Imza = belirsizligin parmak izi (brandId|olcu|tip|cins-ipucu).
// Kullanici bazli: bir firmanin tercihi digerine dayatilmaz. ML/embedding YOK —
// duz alias tablosu; ayni imza ikinci kez gelince secici atlanir, 'oneri' dolar.
model EslesmeHafizasi {
  id             String   @id @default(uuid())
  userId         String
  imza           String
  // Secilen KUTUPHANE urununun ADI (id degil — kutuphane satiri silinip
  // yeniden aktarilabilir; ad ile guncel kutuphanede tekrar bulunur).
  secilenAd      String
  secimSayisi    Int      @default(1)
  sonSecimTarihi DateTime @updatedAt

  @@unique([userId, imza])
}

// TERMINOLOJI SOZLUGU (PRD v1.1 §5) — sektorel terim/baslik → kanonik malzeme.
// "SPRINK HATTI BORULARI" basligi kutuphanedeki "Siyah Celik Boru"ya bu tablo
// uzerinden cozumlenir. Seed kayitlar sistemle gelir (TR+EN), kullanici kendi
// alias'larini ekleyebilir (S3); seed silinmez, pasife alinir.
model TerminologyAlias {
  id          String   @id @default(uuid())
  // null = sistem geneli seed; dolu = kullaniciya (hesaba) ozel
  userId      String?
  // NORMALIZE edilmis terim ("sprink hatti") — contains mantigiyla eslesir,
  // en uzun eslesen alias kazanir (S2)
  alias       String
  // Kanonik malzeme anahtari ("siyah_celik_boru", "hdpe_pe100_boru")
  canonical   String
  // Cins ipuclari (KIND_TAGS uyumlu: celik/ppr/hdpe/pe/pvc...) — tie-break,
  // sert filtre degil
  kinds       String[] @default([])
  // Ima edilen malzeme tipi ('boru' vb.) — tip belirsizligini cozer
  impliedType String?
  // Cap cevrim sinifi: 'steel' | 'plastic' | null (belirsiz)
  sizeClass   String?
  // Bu islevsel kelimeden uretilen ve elemeye girmemesi gereken tag'ler
  stripTags   String[] @default([])
  active      Boolean  @default(true)
  createdBy   String   @default("seed") // 'seed' | 'user'
  createdAt   DateTime @default(now())

  @@unique([userId, alias])
  @@index([userId])
}

// MARKA → MALZEME TIPI (PRD §10.4, D2/P1) — marka adindaki uretici deseni
// malzeme sinifini belirler: Cayirova → celik (DN↔inc), Kalde → PPR (DN=mm).
model BrandMaterialType {
  id        String   @id @default(uuid())
  userId    String?  // null = seed; dolu = kullanici ekledi
  // NORMALIZE uretici deseni ("cayirova") — marka adinda contains aranir,
  // "X veya muadili" kaliplarini da yakalar
  pattern   String
  kinds     String[] @default([])
  sizeClass String   // 'steel' | 'plastic'
  active    Boolean  @default(true)
  createdBy String   @default("seed")
  createdAt DateTime @default(now())

  @@unique([userId, pattern])
  @@index([userId])
}

// Kullanicinin kendi marka kutuphanesi — ExcelGrid gorunumu icin sheets JSON
// UserLibrary (satir bazli, matching icin) ile paralel calisir
model UserBrandLibrary {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  brand     Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  brandId   String
  sheets    Json     // ExcelGrid raw sheets yapisi (multi-sheet, grup basliklari, merge cells)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, brandId])
  @@index([userId])
}

model UserSubscription {
  id        String            @id @default(uuid())
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  level     PackageLevel
  scope     SubscriptionScope
  startsAt  DateTime          @default(now())
  endsAt    DateTime?
  active    Boolean           @default(true)
  createdAt DateTime          @default(now())

  @@unique([userId, level, scope])
  @@index([userId])
}

model Brand {
  id              String              @id @default(uuid())
  name            String              @unique
  logoUrl         String?
  discipline      String              @default("mechanical") // 'mechanical' | 'electrical'
  priceLists      PriceList[]
  materialPrices  MaterialPrice[]
  userLibrary     UserLibrary[]
  userLibraries   UserBrandLibrary[]
  quoteItems      QuoteItem[]
}

model PriceList {
  id            String          @id @default(uuid())
  name          String
  brand         Brand           @relation(fields: [brandId], references: [id], onDelete: Cascade)
  brandId       String
  createdAt     DateTime        @default(now())
  items         MaterialPrice[]
  userLibraries UserLibrary[]
}

model Material {
  id             String          @id @default(uuid())
  name           String          @unique
  unit           String?
  category       String?
  listPrice      Float?
  isGlobal       Boolean         @default(true)
  tags           String[]        @default([])
  normalizedName String?
  materialType   String?
  materialPrices MaterialPrice[]
  userLibrary    UserLibrary[]

  @@index([materialType])
}

model MaterialPrice {
  id          String     @id @default(uuid())
  material    Material   @relation(fields: [materialId], references: [id], onDelete: Cascade)
  materialId  String
  brand       Brand      @relation(fields: [brandId], references: [id], onDelete: Cascade)
  brandId     String
  priceList   PriceList? @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  priceListId String?
  price       Float
  // ── KAYNAK SADAKATI (Duzeltme Talebi Y1/Y2/Y5): yuklenen dosyanin yapisi
  // liste-kalemi seviyesinde BIREBIR saklanir. Material global-unique kalir;
  // gorunum ve yapi bu alanlardan beslenir.
  // Dosyadaki kategori basligi ("Esnek Metal Hortum / Orgulu Hortum")
  kategori    String?
  // MALZEME CINSI sutunu (bossa null — miras tagging'de, veri bozulmaz)
  cins        String?
  // CAP sutunu (ayri alan — esletirme tag'lerine de katilir, E6)
  cap         String?
  // MALZEME ADI hucresi BIREBIR (Material.name benzersizlik icin birlesik olabilir)
  adRaw       String?
  // BIRIM hucresi birebir
  birimRaw    String?
  // Kaynak satir sirasi (Y5: sistem yeniden siralamaz)
  sortOrder   Int        @default(0)
  // Role oturmayan ek sutunlar { "Kolon Adi": "deger" } (Y2: sutun dusurulmez)
  extra       Json?

  @@unique([materialId, brandId, priceListId])
}

model UserLibrary {
  id                String     @id @default(uuid())
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            String
  material          Material?  @relation(fields: [materialId], references: [id])
  materialId        String?
  materialName      String?
  brand             Brand      @relation(fields: [brandId], references: [id])
  brandId           String
  customPrice       Float?
  discountRate      Float?
  listPrice         Float?
  unit              String?
  sourcePriceList   PriceList? @relation(fields: [sourcePriceListId], references: [id], onDelete: SetNull)
  sourcePriceListId String?
  // Sarf malzemesi / ekipman icin ek teknik ozellikler. Serbest key-value JSON.
  // Ornek: { "power": "24 kW", "capacity": "100 m3/h", "voltaj": "220V" }
  // DWG workspace'te INSERT (ekipman) noktasina atanan malzemenin guc/kapasite
  // gibi bilgileri burada tutulur, hesaplamaya/cikti'ya dahil edilir.
  specs             Json?
  // "ekipman" | "boru" | "fitting" | null — DWG equipment popup filtre icin
  category          String?
}

model Quote {
  id           String      @id @default(uuid())
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  title        String?
  sheets       Json?       // Multi-sheet Excel raw state (SheetData[]), null = legacy tek-sheet quote
  originalFile Bytes?      // Orijinal Excel dosya binary'si — indirirken fiyatlar uzerine yazilir
  originalName String?     // Orijinal dosya adi (orn. "SAHINKUL KESIF OZETI.xlsx")
  createdAt    DateTime    @default(now())
  items        QuoteItem[]
}

model QuoteItem {
  id                 String     @id @default(uuid())
  quote              Quote      @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  quoteId            String
  materialName       String
  unit               String     @default("Adet")
  brand              Brand?     @relation(fields: [brandId], references: [id])
  brandId            String?
  laborFirma         LaborFirm? @relation(fields: [laborFirmaId], references: [id])
  laborFirmaId       String?
  quantity           Float
  // Malzeme fiyatlari
  materialUnitPrice  Float   @default(0)
  materialTotalPrice Float   @default(0)
  materialMargin     Float   @default(0)  // %
  // Iscilik fiyatlari
  laborUnitPrice     Float   @default(0)
  laborTotalPrice    Float   @default(0)
  laborMargin        Float   @default(0)  // %
  // Toplamlar
  totalUnitPrice     Float   @default(0)
  totalPrice         Float   @default(0)
  // Eski alanlar (geriye uyumluluk)
  unitPrice          Float   @default(0)
  discount           Float   @default(0)
  netPrice           Float   @default(0)
  profitMargin       Float   @default(0)
  finalPrice         Float   @default(0)
}

enum Discipline {
  mechanical
  electrical
}

model LaborItem {
  id             String       @id @default(uuid())
  name           String
  unit           String       @default("Adet")
  unitPrice      Float                            // varsayilan/baz fiyat
  discipline     Discipline
  category       String?
  description    String?
  tags           String[]     @default([])
  normalizedName String?
  isGlobal       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  laborPrices    LaborPrice[]

  @@index([discipline])
  @@index([name])
  @@index([tags], type: Gin)
}

// LaborFirm KULLANICIYA AIT — her kullanici kendi firmalarini olusturur
model LaborFirm {
  id          String           @id @default(uuid())
  name        String
  discipline  Discipline
  logo        String?
  createdAt   DateTime         @default(now())
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  laborPrices LaborPrice[]
  priceLists  LaborPriceList[]
  quoteItems  QuoteItem[]

  @@unique([userId, name])
  @@index([userId])
  @@index([discipline])
}

model LaborPriceList {
  id         String       @id @default(uuid())
  name       String
  firma      LaborFirm    @relation(fields: [firmaId], references: [id], onDelete: Cascade)
  firmaId    String
  uploadedAt DateTime     @default(now())
  sheets     Json?        // ExcelGrid raw sheet — yuklenen dosyanin sheet icerigi (tek sheet, multi-row header, grup basliklari)
  prices     LaborPrice[]
}

model LaborPrice {
  id           String          @id @default(uuid())
  laborItem    LaborItem       @relation(fields: [laborItemId], references: [id], onDelete: Cascade)
  laborItemId  String
  firma        LaborFirm       @relation(fields: [firmaId], references: [id], onDelete: Cascade)
  firmaId      String
  priceList    LaborPriceList? @relation(fields: [priceListId], references: [id], onDelete: SetNull)
  priceListId  String?
  unitPrice    Float           // liste fiyat
  discountRate Float           @default(0)  // iskonto %
  unit         String          @default("Adet")
  createdAt    DateTime        @default(now())

  @@unique([laborItemId, firmaId, priceListId])
  @@index([firmaId])
  @@index([laborItemId])
}

model AiUsageLog {
  id            String   @id @default(uuid())
  feature       String   // 'pdf_parse' | 'excel_match' | 'quote_analyze'
  provider      String   // 'claude' | 'gemini' | 'openrouter'
  model         String?  // 'claude-sonnet-4-6' etc.
  inputTokens   Int      @default(0)
  outputTokens  Int      @default(0)
  estimatedCost Float    @default(0) // USD
  success       Boolean  @default(true)
  errorMessage  String?
  createdAt     DateTime @default(now())

  @@index([feature])
  @@index([createdAt])
}

model SystemSettings {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

