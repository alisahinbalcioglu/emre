# ═════════════════════════════════════════════════════════════════
#  MetaPrice VPS — docker-compose environment
#  Kopyala:  cp .env.example .env   → degerleri doldur
#  .env ASLA commit edilmez (.gitignore'da).
# ═════════════════════════════════════════════════════════════════

# ── Domain + HTTPS ──────────────────────────────────────────────
DOMAIN=metapricex.com
ACME_EMAIL=emre.basarann1@gmail.com

# ── PostgreSQL ──────────────────────────────────────────────────
POSTGRES_USER=metaprice
# Guclu bir sifre uret:  openssl rand -base64 24
POSTGRES_PASSWORD=DEGISTIR_guclu_sifre
POSTGRES_DB=metaprice

# ── JWT (login token imzasi) ────────────────────────────────────
# Uret:  openssl rand -base64 48
JWT_SECRET=DEGISTIR_uzun_rastgele

# ── DWG engine ic token (NestJS <-> Python ayni deger) ──────────
# Uret:  openssl rand -base64 32
INTERNAL_API_TOKEN=DEGISTIR_uzun_rastgele

# ── Claude API (PDF/DWG AI ozellikleri) ─────────────────────────
ANTHROPIC_API_KEY=sk-ant-DEGISTIR
