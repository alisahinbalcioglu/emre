# ───────────────────────────────────────────────────────────
# MetaPrice Frontend — Environment template
# Kopyala: cp .env.example .env.local, degerleri doldur.
# .env.local .gitignore'da — ASLA commit etme.
# ───────────────────────────────────────────────────────────

# Backend NestJS API URL'i — Axios bu base'i kullanir.
# Locale: http://localhost:3001/api
# Production: Render API URL'i + /api (Netlify env'inde set et)
NEXT_PUBLIC_API_URL="http://localhost:3001/api"
